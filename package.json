{
  "name": "@mukundakatta/ai-eval-forge",
  "version": "0.1.1",
  "description": "Zero-dependency eval harness for LLM and agent regression testing.",
  "type": "module",
  "bin": {
    "ai-eval-forge": "src/cli.js",
    "aef": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "find src test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "build": "npm run check",
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "ci": "npm run check && npm test && npm run pack:check"
  },
  "keywords": [
    "ai",
    "llm",
    "evals",
    "agents",
    "rag",
    "regression-testing"
  ],
  "author": "Mukunda Katta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MukundaKatta/ai-eval-forge-js.git"
  },
  "bugs": {
    "url": "https://github.com/MukundaKatta/ai-eval-forge-js/issues"
  },
  "homepage": "https://github.com/MukundaKatta/ai-eval-forge-js#readme",
  "engines": {
    "node": ">=18"
  }
}
